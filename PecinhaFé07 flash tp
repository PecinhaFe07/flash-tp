local function getPingBase()
    local ping = 80
    pcall(function() ping = LocalPlayer:GetNetworkPing() * 1000 end)
    if ping <= 30 then return 0.91
    elseif ping <= 70 then return 0.92
    elseif ping <= 120 then return 0.93
    else return 0.94 end
end

local function FindTool(key)
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local ch = LocalPlayer.Character
    if ch then for _,t in pairs(ch:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower():find(key:lower()) then return t end
    end end
    if bp then for _,t in pairs(bp:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower():find(key:lower()) then return t end
    end end
end

local function PerformAlign(p, a)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    local carpet = FindTool("flying")
    if carpet then hum:EquipTool(carpet); task.wait(0.05) end
    hrp.Velocity = Vector3.new(0,0,0)
    hrp.CFrame = CFrame.new(p)
    task.wait(0.1)
    workspace.CurrentCamera.CFrame = CFrame.new(LocalPlayer.Character.Head.Position, a)
end

local function GetNearestPoint()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local side = (hrp.Position.Z > Z_THRESHOLD) and AimLocations.Right or AimLocations.Left
    local target, minDist = nil, math.huge
    for _, pt in ipairs(side) do
        local d = (hrp.Position - pt.pos).Magnitude
        if d < minDist then minDist = d; target = pt end
    end
    return target
end

local function flashStart()
    if ppsConn then ppsConn:Disconnect() end
    ppsConn = ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
        if not flashEnabled then return end
        if activeTriggers[prompt] then return end
        activeTriggers[prompt] = true
        local start = os.clock()
        local fired = false
        local conn
        conn = RunService.PreRender:Connect(function()
            if not prompt or not prompt.Parent then
                conn:Disconnect(); activeTriggers[prompt] = nil
                if barFill then TweenService:Create(barFill, TweenInfo.new(0.3), {Size=UDim2.new(0,0,1,0)}):Play() end
                return
            end
            local progress = math.clamp((os.clock()-start)/prompt.HoldDuration, 0, 1)
            if barFill then barFill.Size = UDim2.new(progress,0,1,0) end
            if not fired and progress >= flashSliderValue then
                fired = true; conn:Disconnect(); activeTriggers[prompt] = nil
                triggerBump = not triggerBump
                local ch = LocalPlayer.Character
                local tool = ch and ch:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
                if barFill then
                    barFill.Size = UDim2.new(1,0,1,0)
                    task.delay(0.2, function()
                        TweenService:Create(barFill, TweenInfo.new(0.4), {Size=UDim2.new(0,0,1,0)}):Play()
                    end)
                end
            end
        end)
        prompt.PromptButtonHoldEnded:Connect(function()
            if not fired then
                conn:Disconnect(); activeTriggers[prompt] = nil
                if barFill then TweenService:Create(barFill, TweenInfo.new(0.3), {Size=UDim2.new(0,0,1,0)}):Play() end
            end
        end)
    end)

    if hbConn then hbConn:Disconnect() end
    hbConn = RunService.Heartbeat:Connect(function()
        if not manualOverride then
            local base = getPingBase()
            flashSliderValue = triggerBump and base+0.01 or base
        end
    end)
end

local function flashStop()
    if ppsConn then ppsConn:Disconnect(); ppsConn = nil end
    if hbConn then hbConn:Disconnect(); hbConn = nil end
    activeTriggers = {}
    if barFill then TweenService:Create(barFill, TweenInfo.new(0.3), {Size=UDim2.new(0,0,1,0)}):Play() end
end

